{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chu-kei.example/schemas/commercial-offers.schema.json",
  "title": "Chu-kei Commercial Offers v1",
  "type": "object",
  "required": ["schemaVersion", "updatedAt", "currency", "taxIncluded", "offers", "commonTerms"],
  "properties": {
    "schemaVersion": {"const": "commercial-offers-v1"},
    "updatedAt": {"type": "string", "format": "date"},
    "currency": {"const": "JPY"},
    "taxIncluded": {"type": "boolean"},
    "offers": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "name", "status", "priceFrom", "scope", "requiredReview"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "status": {"enum": ["pilot", "active", "paused"]},
          "priceFrom": {"type": "integer", "minimum": 0},
          "scope": {
            "type": "object",
            "required": ["maximumCompanies", "deliverables"],
            "properties": {
              "maximumCompanies": {"type": "integer", "minimum": 1},
              "deliverables": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
            },
            "additionalProperties": false
          },
          "requiredReview": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
        },
        "additionalProperties": false
      }
    },
    "commonTerms": {
      "type": "object",
      "required": ["investmentAdvice", "officialSourcesFirst", "unknownValuesRemainUnknown", "deliverySchedule", "includedRevisions", "confidentialHandling"],
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
