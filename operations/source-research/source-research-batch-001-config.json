{
  "schemaVersion": "source-research-batch-v1",
  "batchId": "source-research-batch-001",
  "runRequested": true,
  "batchSize": 25,
  "concurrency": 5,
  "excludeCodes": [],
  "outputPath": "operations/source-research/source-research-batch-001-candidates.json",
  "selectionPolicy": {
    "stage": "jpx_indexed",
    "preferMarkets": ["Prime", "Growth", "Standard"],
    "preferIndustries": [
      "情報・通信業",
      "電気機器",
      "機械",
      "精密機器",
      "サービス業",
      "医薬品",
      "化学",
      "輸送用機器",
      "銀行業",
      "証券、商品先物取引業",
      "保険業",
      "不動産業"
    ]
  },
  "safety": {
    "automaticFactCompletion": false,
    "automaticApproval": false,
    "automaticProductionPromotion": false,
    "requireJpxCodeSpecificDisclosure": true,
    "requirePdfPageEvidence": true,
    "requirePublicationDate": true,
    "requireIdentityMatchBeforeApproval": true
  }
}
