{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chu-kei.example/schemas/correction-entry-v1.schema.json",
  "title": "Chu-kei Correction Entry v1",
  "type": "object",
  "required": ["id", "companyCode", "fieldPath", "reason", "sourceUrl", "detectedAt", "status"],
  "properties": {
    "id": {"type": "string", "pattern": "^correction-[0-9A-Z]{4}-[0-9]{8}-[a-z0-9-]+$"},
    "companyCode": {"type": "string", "pattern": "^[0-9A-Z]{4}$"},
    "fieldPath": {"type": "string", "minLength": 1},
    "before": {},
    "after": {},
    "reason": {"type": "string", "minLength": 1},
    "sourceUrl": {"type": "string", "pattern": "^https://"},
    "sourcePage": {"type": ["string", "null"]},
    "status": {"enum": ["open", "confirmed", "corrected", "rejected"]},
    "reviewDecisionId": {"type": ["string", "null"]},
    "detectedAt": {"type": "string", "format": "date-time"},
    "correctedAt": {"type": ["string", "null"], "format": "date-time"}
  },
  "additionalProperties": false
}
