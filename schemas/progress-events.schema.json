{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://chu-kei.example/schemas/progress-events.schema.json","title":"Chu-kei Progress Events v1","type":"object","required":["schemaVersion","updatedAt","events"],"properties":{"schemaVersion":{"const":"progress-events-v1"},"updatedAt":{"type":"string","format":"date"},"events":{"type":"array","items":{"$ref":"#/$defs/event"}}},"additionalProperties":false,"$defs":{"event":{"type":"object","required":["eventId","companyCode","metric","eventType","effectiveDate","sourceUrl","evidenceRef"],"properties":{"eventId":{"type":"string","minLength":1},"companyCode":{"type":"string","pattern":"^[0-9A-Z]{4}$"},"metric":{"type":"string","minLength":1},"eventType":{"enum":["target_set","target_raised","target_lowered","forecast_updated","actual_reported","period_extended","metric_changed","plan_withdrawn"]},"effectiveDate":{"type":"string","pattern":"^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$"},"beforeValue":{},"afterValue":{},"unit":{"type":"string"},"sourceUrl":{"type":"string","pattern":"^https://"},"evidenceRef":{"type":"string","minLength":1},"note":{"type":"string"}},"additionalProperties":false}}}
