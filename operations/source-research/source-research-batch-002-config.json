{
  "schemaVersion": "source-research-batch-v1",
  "batchId": "source-research-batch-002",
  "batchSize": 200,
  "concurrency": 12,
  "excludeCodes": [],
  "outputPath": "operations/source-research/source-research-batch-002-candidates.json",
  "selectionPolicy": {
    "stage": "jpx_indexed",
    "scope": "next 200 companies",
    "priority": "market, industry and holding-company score"
  },
  "safety": {
    "automaticFactCompletion": false,
    "automaticApproval": false,
    "automaticProductionPromotion": false,
    "requireJpxCodeSpecificDisclosure": true,
    "requirePdfPageEvidence": true,
    "requirePublicationDate": true,
    "requireIdentityMatchBeforeApproval": true,
    "automaticConnectedStatusAllowed": false
  }
}
