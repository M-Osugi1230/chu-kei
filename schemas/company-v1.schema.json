{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chu-kei.example/schemas/company-v1.schema.json",
  "title": "Chu-kei Company v1",
  "type": "object",
  "required": ["code", "name", "market", "industry", "stage", "tier", "lastVerifiedDate", "themes", "summary", "quality", "flags"],
  "properties": {
    "code": {"type": "string", "pattern": "^[0-9A-Z]{4}$"},
    "name": {"type": "string", "minLength": 1},
    "market": {"enum": ["Prime", "Standard", "Growth"]},
    "industry": {"type": "string", "minLength": 1},
    "category": {"type": ["string", "null"]},
    "stage": {"enum": ["core", "detailed_extracted", "source_indexed", "jpx_indexed"]},
    "tier": {"type": "string", "minLength": 1},
    "sourceUrl": {"type": ["string", "null"]},
    "document": {"type": ["string", "null"]},
    "period": {"type": ["string", "null"]},
    "planPublishedDate": {"type": ["string", "null"], "pattern": "^$|^\\d{4}(-\\d{2})?(-\\d{2})?$"},
    "lastVerifiedDate": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "themes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "summary": {"type": "string"},
    "revenue": {"type": ["string", "null"]},
    "profit": {"type": ["string", "null"]},
    "margin": {"type": ["string", "null"]},
    "capital": {"type": ["string", "null"]},
    "returnPolicy": {"type": ["string", "null"]},
    "highlights": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "evidenceRefs": {"type": "array", "items": {"type": "string"}},
    "quality": {"$ref": "quality-profile-v1.schema.json"},
    "flags": {"type": "object", "additionalProperties": {"type": "boolean"}}
  },
  "additionalProperties": true
}
