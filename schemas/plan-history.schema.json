{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://chu-kei.example/schemas/plan-history.schema.json","title":"Chu-kei Plan History v1","type":"object","required":["schemaVersion","updatedAt","companies"],"properties":{"schemaVersion":{"const":"plan-history-v1"},"updatedAt":{"type":"string","format":"date"},"companies":{"type":"array","items":{"$ref":"#/$defs/company"}}},"additionalProperties":false,"$defs":{"company":{"type":"object","required":["code","name","plans"],"properties":{"code":{"type":"string","pattern":"^[0-9A-Z]{4}$"},"name":{"type":"string","minLength":1},"summary":{"type":"string"},"plans":{"type":"array","minItems":2,"items":{"$ref":"#/$defs/plan"}}},"additionalProperties":false},"plan":{"type":"object","required":["planId","name","period","publicationDate","sourceUrl","status"],"properties":{"planId":{"type":"string","minLength":1},"name":{"type":"string","minLength":1},"period":{"type":"string","minLength":1},"publicationDate":{"type":"string","pattern":"^[0-9]{4}(-[0-9]{2}(-[0-9]{2})?)?$"},"sourceUrl":{"type":"string","pattern":"^https://"},"status":{"enum":["active","completed","replaced","withdrawn"]},"outcomeLabel":{"enum":["進行中","達成","一部達成","未達","撤回","判定不能"]},"evidenceRefs":{"type":"array","items":{"type":"string","minLength":1}}},"additionalProperties":false}}}
