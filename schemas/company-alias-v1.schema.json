{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chu-kei.example/schemas/company-alias-v1.schema.json",
  "title": "Chu-kei Company Alias v1",
  "type": "object",
  "required": ["canonicalCode", "alias", "aliasType", "source", "verifiedAt"],
  "properties": {
    "canonicalCode": {"type": "string", "pattern": "^[0-9A-Z]{4}$"},
    "alias": {"type": "string", "minLength": 1},
    "aliasType": {"enum": ["former_name", "abbreviation", "english_name", "spacing_variant", "legal_suffix_variant", "other"]},
    "source": {"type": "string", "pattern": "^https://"},
    "verifiedAt": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "note": {"type": ["string", "null"]}
  },
  "additionalProperties": false
}
